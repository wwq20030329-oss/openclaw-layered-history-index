{
  "id": "layered-history-index",
  "name": "Layered History Index",
  "description": "Layered L0/L1/L2 conversation indexing inspired by OpenViking.",
  "version": "0.1.3",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "alwaysLoadL0": {
        "type": "boolean",
        "default": false
      },
      "captureWithLlm": {
        "type": "boolean",
        "default": true
      },
      "llmRouting": {
        "type": "boolean",
        "default": true
      },
      "l0PromptEntries": {
        "type": "integer",
        "default": 20,
        "minimum": 10,
        "maximum": 200
      },
      "maxTimelineEntries": {
        "type": "integer",
        "default": 100,
        "minimum": 50,
        "maximum": 1000
      },
      "l1PromptChars": {
        "type": "integer",
        "default": 2500,
        "minimum": 500,
        "maximum": 20000
      },
      "l1MaxLines": {
        "type": "integer",
        "default": 4,
        "minimum": 1,
        "maximum": 20
      },
      "l2PromptChars": {
        "type": "integer",
        "default": 6000,
        "minimum": 1000,
        "maximum": 30000
      },
      "l2MaxSessions": {
        "type": "integer",
        "default": 1,
        "minimum": 0,
        "maximum": 5
      },
      "recentDaysForRecall": {
        "type": "integer",
        "default": 2,
        "minimum": 1,
        "maximum": 14
      },
      "recentTsidsForRecall": {
        "type": "integer",
        "default": 2,
        "minimum": 1,
        "maximum": 20
      },
      "routeMaxTokens": {
        "type": "integer",
        "default": 120,
        "minimum": 32,
        "maximum": 1000
      },
      "routeTimelineEntries": {
        "type": "integer",
        "default": 4,
        "minimum": 1,
        "maximum": 40
      },
      "persistRouteTrace": {
        "type": "boolean",
        "default": true
      },
      "routeTraceMaxEntries": {
        "type": "integer",
        "default": 200,
        "minimum": 10,
        "maximum": 1000
      },
      "routeModel": {
        "type": "string",
        "description": "路由判断使用的轻量模型（如 LongCat-Flash-Lite）"
      },
      "routeModelProvider": {
        "type": "string",
        "description": "路由模型所属的提供商（如 qqoq-duckdns-org），留空则根据模型名自动推断"
      },
      "logRoutingFailures": {
        "type": "boolean",
        "default": true,
        "description": "是否在路由失败时输出错误日志"
      },
      "routeCacheTtlSeconds": {
        "type": "integer",
        "default": 300,
        "minimum": 0,
        "maximum": 3600,
        "description": "路由结果缓存时间（秒），0 表示禁用缓存"
      },
      "extraToolPacks": {
        "type": "array",
        "default": [],
        "description": "用户自定义工具包，格式：[{\"name\":\"工具名\",\"description\":\"描述\"}]",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["name", "description"]
        }
      },
      "extraFiles": {
        "type": "array",
        "default": [],
        "description": "用户自定义工作区文件，格式：[{\"name\":\"文件名\",\"description\":\"描述\"}]",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" }
          },
          "required": ["name", "description"]
        }
      },
      "routingPromptTemplate": {
        "type": "object",
        "description": "自定义路由 Prompt 模板",
        "properties": {
          "system": { "type": "string", "description": "系统提示词" },
          "user": { "type": "string", "description": "用户提示词模板，支持 {{userMessage}}, {{timelineSection}}, {{packIndex}}, {{fileIndex}} 变量" }
        }
      },
      "summaryModel": {
        "type": "string"
      },
      "recallKeywords": {
        "type": "array",
        "default": ["回忆", "之前", "上次", "以前", "记得"],
        "items": {
          "type": "string"
        }
      },
      "strongRecallKeywords": {
        "type": "array",
        "default": ["详细", "完整", "所有", "具体"],
        "items": {
          "type": "string"
        }
      },
      "maxHistoryDays": {
        "type": "integer",
        "default": 30,
        "minimum": 7,
        "maximum": 365,
        "description": "自动清理历史文件，保留天数"
      },
      "autoCleanup": {
        "type": "boolean",
        "default": true,
        "description": "是否启用自动清理"
      }
    }
  }
}
