{
  "id": "layered-history-index",
  "name": "Layered History Index",
  "description": "Layered L0/L1/L2 conversation indexing inspired by OpenViking.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "alwaysLoadL0": {
        "type": "boolean"
      },
      "captureWithLlm": {
        "type": "boolean"
      },
      "llmRouting": {
        "type": "boolean"
      },
      "l0PromptEntries": {
        "type": "integer",
        "minimum": 10,
        "maximum": 200
      },
      "maxTimelineEntries": {
        "type": "integer",
        "minimum": 50,
        "maximum": 1000
      },
      "l1PromptChars": {
        "type": "integer",
        "minimum": 500,
        "maximum": 20000
      },
      "l1MaxLines": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "l2PromptChars": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 30000
      },
      "l2MaxSessions": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5
      },
      "recentDaysForRecall": {
        "type": "integer",
        "minimum": 1,
        "maximum": 14
      },
      "recentTsidsForRecall": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "routeMaxTokens": {
        "type": "integer",
        "minimum": 32,
        "maximum": 1000
      },
      "routeTimelineEntries": {
        "type": "integer",
        "minimum": 1,
        "maximum": 40
      },
      "routeModel": {
        "type": "string"
      },
      "summaryModel": {
        "type": "string"
      },
      "recallKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "strongRecallKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
